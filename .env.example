# ─── LogBot Environment Variables ────────────────────────────────────────────
# Copy to .env and fill in values.  Defaults shown are safe for local dev.

# ── App identity ──────────────────────────────────────────────────────────────
APP_NAME=LogBot
APP_VERSION=0.1.0
ENVIRONMENT=development       # development | staging | production | test
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR | CRITICAL
DEBUG=false

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=1
API_RELOAD=true               # set false in production
API_REQUEST_TIMEOUT_SECONDS=30
API_MAX_LOG_LINES_PER_REQUEST=500

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=logbot_logs
CHROMA_DISTANCE_METRIC=cosine # cosine | l2 | ip
CHROMA_PERSIST_DIR=data/embeddings

# ── LLM / HuggingFace ────────────────────────────────────────────────────────
LLM_PROVIDER=huggingface      # huggingface | openai | anthropic
LLM_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2
LLM_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_EMBEDDING_DIM=384
LLM_MAX_NEW_TOKENS=512
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.9
LLM_DEVICE=cpu                # cpu | cuda | mps
LLM_HF_TOKEN=                 # required for gated HF models
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── PySpark ───────────────────────────────────────────────────────────────────
SPARK_APP_NAME=LogBot-Pipeline
SPARK_MASTER=local[*]         # local[*] | spark://<host>:7077 | yarn
SPARK_LOG_LEVEL=WARN
SPARK_BATCH_SIZE=1000
SPARK_MAX_OFFSETS=10000
SPARK_CHECKPOINT_DIR=data/checkpoints
SPARK_RAW_LOG_PATH=data/raw
SPARK_PROCESSED_PATH=data/processed

# ── Anomaly detection ────────────────────────────────────────────────────────
ANOMALY_ISOLATION_FOREST_CONTAMINATION=0.05
ANOMALY_ISOLATION_FOREST_ESTIMATORS=100
ANOMALY_Z_SCORE_THRESHOLD=3.0
ANOMALY_ROLLING_WINDOW_MINUTES=5
ANOMALY_MIN_LOG_SAMPLES=50